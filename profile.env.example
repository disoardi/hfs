# hfs per-user connection profile
#
# Copy to ~/.hfs/profile.env and edit to match your cluster.
# hfs reads this file automatically (before environment variables).
# Environment variables always take priority over this file.
#
# Usage:
#   mkdir -p ~/.hfs
#   cp docs/profile.env.example ~/.hfs/profile.env
#   chmod 600 ~/.hfs/profile.env   # protect credentials

# ── NameNode address ──────────────────────────────────────────────────────────
# Formats:
#   hdfs://namenode.corp.com:8020   → RPC backend (preferred)
#   http://namenode.corp.com:9870   → WebHDFS (Hadoop 3.x)
#   http://namenode.corp.com:50070  → WebHDFS (Hadoop 2.x / HDP)
#   namenode.corp.com:8020          → auto-detects as RPC
#HFS_NAMENODE=hdfs://namenode.corp.com:8020

# ── HDFS user ─────────────────────────────────────────────────────────────────
# The user used for HDFS operations.
# Default: hdfs (allows access from non-Hadoop Linux accounts, e.g. LDAP/AD)
# Set to your own user if you want operations recorded under your identity.
#HFS_USER=hdfs

# ── Backend ───────────────────────────────────────────────────────────────────
# auto (default) | rpc | webhdfs
#HFS_BACKEND=auto

# ── Hadoop configuration directory ───────────────────────────────────────────
# If set, hfs reads core-site.xml from this directory (same as HADOOP_CONF_DIR).
#HADOOP_CONF_DIR=/etc/hadoop/conf

# ── Kerberos ─────────────────────────────────────────────────────────────────
# For WebHDFS SPNEGO: run kinit first, then optionally set KRB5CCNAME.
# For RPC Kerberos (--features kerberos build required): set both.
#
# Example (WebHDFS):
#   kinit -kt /etc/security/keytabs/hdfs.keytab hdfs/$(hostname -f)@CORP.REALM
#   KRB5CCNAME=/tmp/krb5cc_hdfs hfs ls /
#
#KRB5_PRINCIPAL=hdfs/namenode.corp.com@CORP.REALM
#KRB5_KEYTAB=/etc/security/keytabs/hdfs.keytab
