# hfs Docker environment configuration
#
# Copy this file to docker/.env and edit to match your setup.
#   cp docker/.env.example docker/.env
#
# docker/.env is auto-loaded by docker compose when running from the repo root:
#   docker compose -f docker/docker-compose.test.yml up -d
#   docker compose -f docker/docker-compose.kerb.yml up -d
#
# For integration tests against a real cluster, set HFS_* variables and
# export them before running cargo test:
#   set -a; source docker/.env; set +a
#   cargo test --workspace -- --include-ignored

# ── Plain HDFS test cluster (docker-compose.test.yml) ────────────────────────

# Hadoop Docker image (https://hub.docker.com/r/apache/hadoop/tags)
HADOOP_IMAGE=apache/hadoop:3.3.6

# Hive Metastore image (https://hub.docker.com/r/apache/hive/tags)
HIVE_IMAGE=apache/hive:3.1.3

# ── Kerberos test cluster (docker-compose.kerb.yml) ──────────────────────────

# FreeIPA image tag — check https://hub.docker.com/r/freeipa/freeipa-server/tags
# for available tags. fedora-39 was removed; use fedora-42 or rocky-9.
FREEIPA_IMAGE=freeipa/freeipa-server:fedora-42

# Kerberos realm (must match kerb-hadoop-config/core-site.xml and krb5.conf)
KRB5_REALM=HFS.TEST

# IPA admin password (used during FreeIPA bootstrap and setup-principals.sh)
IPA_ADMIN_PASSWORD=Admin1234

# ── hfs client — real cluster integration tests ───────────────────────────────
# Uncomment and fill to run integration tests against your real cluster.
# These are passed directly to the cargo test environment.

# Namenode address. Formats:
#   http://namenode.corp.com:9870   → WebHDFS (Hadoop 3.x)
#   http://namenode.corp.com:50070  → WebHDFS (Hadoop 2.x / HDP)
#   hdfs://namenode.corp.com:8020   → RPC (+ --backend rpc)
#HFS_NAMENODE=http://namenode.corp.com:9870

# HDFS user (overrides HADOOP_USER_NAME)
#HFS_USER=hadoop

# Backend: auto | webhdfs | rpc
#HFS_BACKEND=auto

# Hadoop configuration directory (auto-reads core-site.xml)
#HADOOP_CONF_DIR=/etc/hadoop/conf

# ── Kerberos — real cluster ───────────────────────────────────────────────────
# For WebHDFS SPNEGO: run kinit first, then export KRB5CCNAME.
# hfs picks up the ticket cache automatically via the GSSAPI negotiation.
#
# Example:
#   kinit -kt /etc/security/keytabs/hfs.keytab hfs/$(hostname -f)@CORP.REALM
#   KRB5CCNAME=/tmp/krb5cc_hfs HFS_NAMENODE=http://namenode:50070 hfs ls /
#
# For RPC Kerberos (--features kerberos build required):
#   HFS_NAMENODE=hdfs://namenode:8020 HFS_KERBEROS=true hfs ls /
#
#KRB5CCNAME=/tmp/krb5cc_hfs
#HFS_KERBEROS=true
