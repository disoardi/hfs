# hfs connection profile
#
# One file per environment: prod.env, staging.env, dev.env, etc.
#
# Usage:
#   hfs --env-file /path/to/prod.env ls /
#   hfs --env-file ~/envs/staging.env du /user/hive/warehouse
#
# Default location (loaded automatically when --env-file is not specified):
#   ~/.hfs/profile.env
#
# Setup:
#   mkdir -p ~/.hfs
#   cp docs/profile.env.example ~/.hfs/profile.env
#   chmod 600 ~/.hfs/profile.env   # protect credentials
#
# Values may be quoted with single or double quotes.
# Lines starting with # are comments. Blank lines are ignored.

# ── NameNode address ──────────────────────────────────────────────────────────
# Formats:
#   hdfs://namenode.corp.com:8020   → RPC (preferred, auto-detected by port)
#   http://namenode.corp.com:9870   → WebHDFS (Hadoop 3.x)
#   http://namenode.corp.com:50070  → WebHDFS (Hadoop 2.x / HDP)
#   namenode.corp.com:8020          → auto-detected as RPC
#   namenode.corp.com:50070         → auto-detected as WebHDFS
#
# Note: if HADOOP_CONF_DIR is set and core-site.xml contains fs.defaultFS,
# this variable is not needed.
#HFS_NAMENODE=hdfs://namenode.corp.com:8020

# ── HDFS user ─────────────────────────────────────────────────────────────────
# The user submitted with WebHDFS requests (&user.name=) and set as
# HADOOP_USER_NAME for RPC connections.
# Default: hdfs (allows access from any Linux account, e.g. LDAP/AD users).
# Set to your personal user if you want operations attributed to your identity.
#HFS_USER=hdfs

# ── Backend ───────────────────────────────────────────────────────────────────
# auto     — try RPC first, fall back to WebHDFS (default)
# rpc      — force native HDFS RPC (hdfs-native, port 8020)
# webhdfs  — force WebHDFS REST API (port 9870 / 50070)
#HFS_BACKEND=auto

# ── Hadoop client configuration directory ─────────────────────────────────────
# Path to a directory containing Hadoop XML config files.
# hfs reads the following files (in order) if present:
#   core-site.xml   → fs.defaultFS, hadoop.security.authentication
#   hdfs-site.xml   → dfs.namenode.http-address, dfs.namenode.rpc-address,
#                     dfs.namenode.kerberos.principal, etc.
#   mapred-site.xml, yarn-site.xml — merged into raw_hadoop_props for future use
#
# If both HADOOP_CONF_DIR and HFS_NAMENODE are set, HFS_NAMENODE takes priority.
# If the cluster uses Kerberos (hadoop.security.authentication=kerberos),
# set KRB5_PRINCIPAL + KRB5_KEYTAB below.
#HADOOP_CONF_DIR=/etc/hadoop/conf

# ── Kerberos ─────────────────────────────────────────────────────────────────
# For WebHDFS SPNEGO (no --features flag needed):
#   1. Run kinit before hfs, or set KRB5_PRINCIPAL + KRB5_KEYTAB here.
#   2. hfs picks up the ticket cache via GSSAPI negotiation.
#
# For RPC Kerberos (requires build with --features kerberos):
#   Set both KRB5_PRINCIPAL and KRB5_KEYTAB.
#
# Examples:
#   KRB5_PRINCIPAL=hdfs/namenode.corp.com@CORP.REALM
#   KRB5_KEYTAB=/etc/security/keytabs/hdfs.keytab
#
#KRB5_PRINCIPAL=hdfs@CORP.REALM
#KRB5_KEYTAB=/etc/security/keytabs/hdfs.keytab
